{
  "name": "tuktuk-tracking-backend-api",
  "version": "1.0.0",
  "description": "This repo is for my Web API Coursework related to Tuk-Tuk tracking (Three-wheel)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate:latest": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status": "knex migrate:list",
    "seed:run": "knex seed:run",
    "db:reset": "docker-compose down -v && docker-compose up -d"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Liviru-Nava/tuktuk-tracking-backend-api.git"
  },
